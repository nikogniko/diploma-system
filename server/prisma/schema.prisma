// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// ==========================================
// НАЛАШТУВАННЯ PRISMA
// ==========================================

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// СИСТЕМНІ ПЕРЕЛІКИ (ENUMS)
// ==========================================

enum UserRole {
  STUDENT
  HR
  SYS_ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  BLOCKED
  DELETED
}

enum OutboxEventType {
  CREATED
  UPDATED
  DELETED
}

enum RegistrationType {
  COMPANY
  FOP
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_20
  SIZE_21_50
  SIZE_51_100
  SIZE_101_200
  SIZE_201_500
  SIZE_501_1000
  SIZE_1000_PLUS
}

enum ProfileVisibility {
  PUBLIC
  APPLIED_ONLY
  HIDDEN
}

enum Gender {
  MALE
  FEMALE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SkillCategory {
  HARD_SKILL
  SOFT_SKILL
  TOOL
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  NATIVE
}

enum Degree {
  JUNIOR_BACHELOR
  BACHELOR
  MASTER
  PHD
  OTHER
}

enum LinkType {
  WEBSITE
  MESSENGER
  SOCIAL
  PORTFOLIO
  OTHER
}

enum SalaryPeriod {
  PER_MONTH
  PER_HOUR
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum RequirementWeight {
  CRITICAL
  IMPORTANT
  NICE_TO_HAVE
}

// ==========================================
// СИСТЕМНІ ТАБЛИЦІ (ІНФРАСТРУКТУРА)
// ==========================================

model OutboxEvent {
  id            String          @id @default(uuid())
  aggregateType String          @db.VarChar(100) 
  aggregateId   String          @db.VarChar(100) 
  eventType     OutboxEventType 
  payload       Json     
  status        String          @default("PENDING") @db.VarChar(50) 
  createdAt     DateTime        @default(now())

  @@index([status, createdAt])
}

// Універсальна таблиця посилань (Links)
model Link {
  id               String          @id @default(uuid())
  linkType         LinkType
  linkName         String          @db.VarChar(100) 
  value            String          @db.VarChar(255) 
  
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  companyId        String?
  company          Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  hrProfileId      String?
  hrProfile        HrProfile?      @relation(fields: [hrProfileId], references: [id], onDelete: Cascade)
}

// ==========================================
// ДОВІДНИКИ 
// ==========================================

model Skill {
  id           Int               @id @default(autoincrement())
  name         String            @unique @db.VarChar(100)
  category     SkillCategory
  
  courses      CourseSkill[]
  projects     ProjectSkill[]
  experience   ExperienceSkill[]
  vacancySkills VacancySkill[]
}

model Language {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(50) 
  
  profiles         LanguageSkill[] 
  vacancyLanguages VacancyLanguage[]
}

model University {
  id         Int              @id @default(autoincrement())
  name       String           @unique @db.VarChar(200)
  education  Education[] 
}

model Profession {
  id                Int                        @id @default(autoincrement())
  name              String                     @unique @db.VarChar(150)
  
  experience        Experience[] 
  vacancies         Vacancy[]
  studentDesired    StudentDesiredProfession[]
}

model Sphere {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(150)
  
  experience     Experience[] 
  companySpheres CompanySphere[]
  vacancySpheres VacancySphere[]
}

model EmploymentType {
  id         Int                     @id @default(autoincrement())
  name       String                  @unique @db.VarChar(100) 
  
  students   StudentEmploymentType[]
  vacancies  VacancyEmploymentType[]
}

model WorkSchedule {
  id         Int                   @id @default(autoincrement())
  name       String                @unique @db.VarChar(100) 
  
  students   StudentWorkSchedule[]
  vacancies  VacancyWorkSchedule[]
}

model WorkFormat {
  id         Int                 @id @default(autoincrement())
  name       String              @unique @db.VarChar(100) 
  
  students   StudentWorkFormat[]
  vacancies  VacancyWorkFormat[]
}

// ==========================================
// ГЕОГРАФІЧНІ ДОВІДНИКИ ТА ЛОКАЦІЯ
// ==========================================

model Country {
  id      Int      @id @default(autoincrement())
  name    String   @unique @db.VarChar(100)
  regions Region[]
}

model Region {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  
  countryId Int
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  cities    City[]

  @@unique([name, countryId]) 
}

model City {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  
  regionId  Int
  region    Region   @relation(fields: [regionId], references: [id], onDelete: Restrict)

  @@unique([name, regionId]) 
}

model Location {
  id        String  @id @default(uuid())
  countryId Int
  regionId  Int?
  cityId    Int?

  studentLocations StudentDesiredLocation[]
  companyLocations CompanyLocation[]
  vacancyLocations VacancyLocation[]

  @@unique([countryId, regionId, cityId]) 
}

// ==========================================
// ЯДРО КОРИСТУВАЧІВ ТА ПРОФІЛІВ
// ==========================================

model User {
  id             String          @id @default(uuid()) 
  clerkUserId    String          @unique @db.VarChar(255)
  email          String          @unique @db.VarChar(255)
  
  role           UserRole   
  status         UserStatus      @default(PENDING_VERIFICATION)
  
  firstName      String          @db.VarChar(100)
  lastName       String          @db.VarChar(100)
  middleName     String?         @db.VarChar(100) 
  photoUrl       String?         @db.VarChar(255) 
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt 

  studentProfile StudentProfile?
  hrProfile      HrProfile?
}

model Company {
  id                 String           @id @default(uuid()) 
  registrationType   RegistrationType
  registrationNumber String           @unique @db.VarChar(50)
  legalName          String           @db.VarChar(200)
  corporateDomain    String?          @db.VarChar(100) 
  verificationStatus ModerationStatus @default(PENDING)
  
  logoUrl            String?          @db.VarChar(255)
  publicName         String           @db.VarChar(100) 
  websiteUrl         String?          @db.VarChar(255)
  foundationYear     Int              @db.SmallInt 
  employeeCount      CompanySize?
  
  about              String           @db.Text 
  publicEmail        String           @db.VarChar(255)
  publicPhone        String?          @db.VarChar(50)
  
  createdAt          DateTime         @default(now())
  
  hrProfiles         HrProfile[]
  links              Link[]
  vacancies          Vacancy[]
  spheres            CompanySphere[]
  locations          CompanyLocation[]
}

model HrProfile {
  id        String   @id @default(uuid()) 
  
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  position  String   @db.VarChar(150) 
  
  links     Link[]
  vacancies Vacancy[]
}

model StudentProfile {
  id              String            @id @default(uuid()) 
  
  userId          String            @unique
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  gender          Gender?
  birthDate       DateTime          @db.Date 
  about           String?           @db.VarChar(500)
  
  contactEmail    String            @db.VarChar(255) 
  primaryPhone    String            @db.VarChar(50)
  secondaryPhone  String?           @db.VarChar(50)
  
  desiredPosition String?           @db.VarChar(150) 
  minSalary       Int?              
  isActiveSearch  Boolean           @default(true)
  visibility      ProfileVisibility @default(APPLIED_ONLY)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  links             Link[]
  education         Education[]
  languages         LanguageSkill[]
  experiences       Experience[]
  projects          Project[]
  courses           Course[]
  
  desiredProfessions StudentDesiredProfession[]
  employmentTypes   StudentEmploymentType[]
  workSchedules     StudentWorkSchedule[]
  workFormats       StudentWorkFormat[]
  desiredLocations  StudentDesiredLocation[]
}

// ==========================================
// ВАКАНСІЯ
// ==========================================

model Vacancy {
  id               String        @id @default(uuid())
  
  hrProfileId      String
  hrProfile        HrProfile     @relation(fields: [hrProfileId], references: [id], onDelete: Cascade)
  
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  title            String        @db.VarChar(200)
  description      String        @db.Text
  
  professionId     Int
  profession       Profession    @relation(fields: [professionId], references: [id], onDelete: Restrict)
  
  isLocationCritical Boolean     @default(false)
  
  minSalary        Int?
  maxSalary        Int?
  salaryPeriod     SalaryPeriod?
  
  status           ListingStatus @default(DRAFT)
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  publishedAt      DateTime?
  closingDate      DateTime      @db.Date
  
  spheres          VacancySphere[]
  employmentTypes  VacancyEmploymentType[]
  workSchedules    VacancyWorkSchedule[]
  workFormats      VacancyWorkFormat[]
  locations        VacancyLocation[]
  skills           VacancySkill[]
  languages        VacancyLanguage[]

  vacancyProposedSkills VacancyProposedSkill[]
}

// ==========================================
// КОМПЕТЕНЦІЇ ТА ДОСВІД СТУДЕНТА
// ==========================================

model Education {
  id                   String          @id @default(uuid())
  
  studentProfileId     String
  studentProfile       StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  universityId         Int?            
  university           University?     @relation(fields: [universityId], references: [id], onDelete: Restrict)
  customUniversityName String?         @db.VarChar(200) 
  
  degree               Degree
  specialty            String          @db.VarChar(200)
  startYear            Int             @db.SmallInt
  endYear              Int?            @db.SmallInt
  diplomaUrl           String?         @db.VarChar(255)
}

model LanguageSkill {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  languageId       Int            
  language         Language       @relation(fields: [languageId], references: [id], onDelete: Restrict)
  
  level            LanguageLevel
  certificateUrl   String?        @db.VarChar(255)

  @@unique([studentProfileId, languageId]) 
}

model Experience {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  professionId     Int            
  profession       Profession     @relation(fields: [professionId], references: [id], onDelete: Restrict)
  
  sphereId         Int            
  sphere           Sphere         @relation(fields: [sphereId], references: [id], onDelete: Restrict)
  
  companyName      String         @db.VarChar(200) 
  position         String         @db.VarChar(200) 
  
  startDate        DateTime       @db.Date
  endDate          DateTime?      @db.Date
  achievements     String         @db.Text
  
  skills           ExperienceSkill[]

  experienceProposedSkills ExperienceProposedSkill[]
}

model Project {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  title            String         @db.VarChar(200)
  description      String         @db.Text
  projectUrl       String?        @db.VarChar(255)
  
  skills           ProjectSkill[]

  projectProposedSkills ProjectProposedSkill[]
}

model Course {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  
  title            String         @db.VarChar(200)
  startDate        DateTime       @db.Date
  endDate          DateTime?      @db.Date
  certificateUrl   String?        @db.VarChar(255)
  
  skills           CourseSkill[]

  courseProposedSkills CourseProposedSkill[]
}

// ==========================================
// ПРОМІЖНІ ТАБЛИЦІ (ЗВ'ЯЗКИ M:N)
// ==========================================

model ExperienceSkill {
  experienceId String     
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  skillId      Int        
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([experienceId, skillId]) 
}

model ProjectSkill {
  projectId String      
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skillId   Int         
  skill     Skill     @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([projectId, skillId]) 
}

model CourseSkill {
  courseId String     
  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skillId  Int        
  skill    Skill      @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([courseId, skillId]) 
}

model StudentDesiredProfession {
  profileId    String
  profile      StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  professionId Int
  profession   Profession     @relation(fields: [professionId], references: [id], onDelete: Restrict)
  @@id([profileId, professionId])
}

model StudentEmploymentType {
  profileId        String
  profile          StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  employmentTypeId Int
  employmentType   EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Restrict)
  @@id([profileId, employmentTypeId])
}

model StudentWorkSchedule {
  profileId      String
  profile        StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  workScheduleId Int
  workSchedule   WorkSchedule   @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)
  @@id([profileId, workScheduleId])
}

model StudentWorkFormat {
  profileId    String
  profile      StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  workFormatId Int
  workFormat   WorkFormat     @relation(fields: [workFormatId], references: [id], onDelete: Restrict)
  @@id([profileId, workFormatId])
}

model StudentDesiredLocation {
  profileId  String
  profile    StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  locationId String
  location   Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  @@id([profileId, locationId])
}

model CompanySphere {
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sphereId  Int
  sphere    Sphere  @relation(fields: [sphereId], references: [id], onDelete: Restrict)
  @@id([companyId, sphereId])
}

model CompanyLocation {
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  @@id([companyId, locationId])
}

model VacancySphere {
  vacancyId String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  sphereId  Int
  sphere    Sphere  @relation(fields: [sphereId], references: [id], onDelete: Restrict)
  @@id([vacancyId, sphereId])
}

model VacancyEmploymentType {
  vacancyId        String
  vacancy          Vacancy        @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  employmentTypeId Int
  employmentType   EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Restrict)
  @@id([vacancyId, employmentTypeId])
}

model VacancyWorkSchedule {
  vacancyId      String
  vacancy        Vacancy      @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  workScheduleId Int
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)
  @@id([vacancyId, workScheduleId])
}

model VacancyWorkFormat {
  vacancyId    String
  vacancy      Vacancy    @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  workFormatId Int
  workFormat   WorkFormat @relation(fields: [workFormatId], references: [id], onDelete: Restrict)
  @@id([vacancyId, workFormatId])
}

model VacancyLocation {
  vacancyId  String
  vacancy    Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  @@id([vacancyId, locationId])
}

model VacancySkill {
  vacancyId String
  vacancy   Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  skillId   Int
  skill     Skill             @relation(fields: [skillId], references: [id], onDelete: Restrict)
  
  weight    RequirementWeight 
  
  @@id([vacancyId, skillId])
}

model VacancyLanguage {
  vacancyId  String
  vacancy    Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  languageId Int
  language   Language      @relation(fields: [languageId], references: [id], onDelete: Restrict)
  
  level      LanguageLevel
  
  @@id([vacancyId, languageId])
}

// ==========================================
// ПРОМІЖНІ ТАБЛИЦІ ДЛЯ НЕПІДТВЕРДЖЕНИХ НАВИЧОК
// ==========================================

model ProposedSkill {
  id         Int              @id @default(autoincrement())
  name       String           @unique @db.VarChar(100)
  status     ModerationStatus @default(PENDING)

  experienceProposedSkills ExperienceProposedSkill[]

  projectProposedSkills ProjectProposedSkill[]

  courseProposedSkills CourseProposedSkill[]

  vacancyProposedSkills VacancyProposedSkill[]
}

model ExperienceProposedSkill {
  experienceId    String
  experience      Experience    @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  
  proposedSkillId Int
  proposedSkill   ProposedSkill @relation(fields: [proposedSkillId], references: [id], onDelete: Restrict)

  @@id([experienceId, proposedSkillId])
}

model ProjectProposedSkill {
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  proposedSkillId Int
  proposedSkill   ProposedSkill @relation(fields: [proposedSkillId], references: [id], onDelete: Restrict)

  @@id([projectId, proposedSkillId])
}

model CourseProposedSkill {
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  proposedSkillId Int
  proposedSkill   ProposedSkill @relation(fields: [proposedSkillId], references: [id], onDelete: Restrict)

  @@id([courseId, proposedSkillId])
}

model VacancyProposedSkill {
  vacancyId       String
  vacancy         Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  
  proposedSkillId Int
  proposedSkill   ProposedSkill @relation(fields: [proposedSkillId], references: [id], onDelete: Restrict)

  weight          RequirementWeight

  @@id([vacancyId, proposedSkillId])
}